{
  "name": "@alexrebula/giselle-sections-data",
  "version": "0.1.0",
  "description": "Pure, type-safe data factories for React/Next.js section-based UIs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexRebula/giselle-sections-data.git"
  },
  "bugs": {
    "url": "https://github.com/AlexRebula/giselle-sections-data/issues"
  },
  "homepage": "https://github.com/AlexRebula/giselle-sections-data#readme",
  "keywords": [
    "react",
    "nextjs",
    "typescript",
    "sections",
    "data-layer",
    "portfolio"
  ],
  "author": "Alex Rebula",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.0",
    "tsup": "^8.5.1",
    "typescript": "5.9",
    "vitest": "^3.0.0"
  }
}
